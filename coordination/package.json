{
  "name": "varaus-coordination",
  "version": "1.0.0",
  "description": "Full-stack coordination system for Varaus applications",
  "main": "dist/index.js",
  "bin": {
    "coordination": "./dist/cli/bin.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "mocha --require ts-node/register tests/**/*.test.ts",
    "test:property": "mocha --require ts-node/register tests/property/**/*.property.test.ts",
    "test:unit": "mocha --require ts-node/register tests/unit/**/*.test.ts",
    "test:integration": "mocha --require ts-node/register tests/integration/**/*.test.ts",
    "start": "npm run build && node dist/cli/bin.js start",
    "start:dev": "ts-node src/cli/bin.ts start",
    "status": "npm run build && node dist/cli/bin.js status",
    "clean": "rm -rf dist",
    "coordination": "npm run build && node dist/cli/bin.js"
  },
  "devDependencies": {
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "chai": "^4.3.10",
    "fast-check": "^3.15.0",
    "mocha": "^10.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "20.x"
  }
}
